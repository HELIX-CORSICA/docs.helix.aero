{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "Helix Flight Planner",
  "colors": {
    "primary": "#078B00",
    "light": "#2AAF22",
    "dark": "#056600"
  },
  "favicon": "/favicon.svg",
  "logo": {
    "light": "/logo/light.svg",
    "dark": "/logo/dark.svg"
  },
  "navigation": {
    "languages": [
      {
        "language": "en",
        "tabs": [
          {
            "tab": "Guides",
            "groups": [
              {
                "group": "Getting started",
                "pages": [
                  "introduction",
                  "quickstart"
                ]
              },
              {
                "group": "User guide",
                "pages": [
                  "guides/mission-planning",
                  "guides/export-formats",
                  "guides/sensors"
                ]
              },
              {
                "group": "Concepts",
                "pages": [
                  "guides/gsd-and-footprint",
                  "guides/altitude-modes",
                  "guides/strip-generation",
                  "guides/leading-lines",
                  "guides/quality-control"
                ]
              }
            ]
          }
        ]
      },
      {
        "language": "fr",
        "tabs": [
          {
            "tab": "Guides",
            "groups": [
              {
                "group": "Pour commencer",
                "pages": [
                  "fr/introduction",
                  "fr/quickstart"
                ]
              },
              {
                "group": "Guide utilisateur",
                "pages": [
                  "fr/guides/mission-planning",
                  "fr/guides/export-formats",
                  "fr/guides/sensors"
                ]
              },
              {
                "group": "Concepts",
                "pages": [
                  "fr/guides/gsd-and-footprint",
                  "fr/guides/altitude-modes",
                  "fr/guides/strip-generation",
                  "fr/guides/leading-lines",
                  "fr/guides/quality-control"
                ]
              }
            ]
          }
        ]
      }
    ],
    "global": {
      "anchors": [
        {
          "anchor": "Portal",
          "href": "https://app.helix.aero",
          "icon": "browser"
        },
        {
          "anchor": "Support",
          "href": "mailto:support@helix.aero",
          "icon": "envelope"
        }
      ]
    }
  },
  "navbar": {
    "links": [
      {
        "label": "App",
        "href": "https://app.helix.aero"
      }
    ],
    "primary": {
      "type": "button",
      "label": "Download",
      "href": "https://app.helix.aero/download"
    }
  },
  "contextual": {
    "options": [
      "copy",
      "view",
      "chatgpt",
      "claude",
      "perplexity",
      "mcp",
      "cursor",
      "vscode"
    ]
  },
  "footer": {
    "socials": {
      "website": "https://helix.aero"
    }
  }
}
